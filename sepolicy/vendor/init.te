type vendor_sysfs_pmic,         sysfs_type, fs_type;
type vendor_sysfs_ccif,         sysfs_type, fs_type;
type vendor_sysfs_fingerprint,  sysfs_type, fs_type;

allow init fingerprint_vendor_data_file:file rename;
allow init hwservicemanager:binder { call transfer };
allow init same_process_hal_file:file execute;
allow init {
    vendor_sysfs_pmic
    vendor_sysfs_ccif
    vendor_sysfs_fingerprint
}:file { open write };
allow init sysfs_batteryinfo:file open;
allow init sysfs_devices_block:file { open write };
allow init system_server:binder call;
allow init teei_control_file:file open;
allow init uhid_device:chr_file { ioctl open write };
allow init hidl_base_hwservice:hwservice_manager add;
allow init sysfs_devices:file open;
